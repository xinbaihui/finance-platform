{
  "name": "server_fast",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/server_fast/app",
  "projectType": "application",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/server_fast",
        "command": "uvicorn app.main:app --reload --port 8000"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/server_fast",
        "command": "ruff check ."
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/server_fast",
        "command": "mypy app"
      }
    }
  },
  "tags": [
    "scope:server",
    "type:app"
  ]
}
